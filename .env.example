# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/demo_requests

# JWT Authentication
JWT_SECRET=supersecuresecretkeychangeinproduction12345!
JWT_EXPIRES_IN=7d

# SMTP Email Configuration (Nodemailer)
# For production, use secure SMTP (e.g. Resend, SendGrid, Gmail App Password)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# Admin Details
ADMIN_EMAIL=admin@youragency.com
ADMIN_DEFAULT_USER=admin
ADMIN_DEFAULT_PASS=AdminSecurePass2026!

# Business Information for Notifications & Branding
COMPANY_NAME="PixelCraft Studios"
COMPANY_EMAIL="hello@pixelcraftstudios.com"
COMPANY_PHONE="+1234567890"
